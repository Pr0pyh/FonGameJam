[resource]
script = ExtResource("1_idtsc")
name = "Džon Tutorijal"
talk_speed = 0.4
messages = Array[String](["de si brate, znaci sumnja se za gradonacelnika da mulja nesto", "na tebi je brate da nadjes dokaze, slikaj dokumente sto je ostavio okolo, trebace nam 5 pazi samo da ne napunis memoriju", "vuci nokiu po ekranu brate da gledas okolo", "okreces se na A i D ili na dugmice na nokiji", "ides brate napred nazad na W i S ili na dugmice na nokiji", "znaci ovaj model nokije ima dugme za slikanje brate tako da na njega ili na SPACE dugme mozes da slikas", "networkovao sam te tako da ce te zovu ljudi da ti pricaju gde su videli gacice brate", "ali nemoj da se javljas nepotrebnim ljudima, ima da te smaraju do bola imas brate bitnija posla", "to je to od mene brate sad prekini poziv da ne pocnem ponovo da ti pricam sve"])
metadata/_custom_type_script = "uid://dnbx5ecpt5ja0"
